{
  "name": "ai-sdk-provider-poe",
  "version": "0.0.0-dev",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./code": {
      "types": "./dist/code.d.ts",
      "import": "./dist/code.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && tsx scripts/build.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "snapshots:list": "tsx scripts/snapshots.ts list",
    "snapshots:list:stale": "tsx scripts/snapshots.ts list:stale",
    "snapshots:delete": "tsx scripts/snapshots.ts delete",
    "snapshots:delete:stale": "tsx scripts/snapshots.ts delete:stale",
    "verify-model": "tsx scripts/verify-model.ts",
    "update-routing": "tsx scripts/update-bundled-routing.ts",
    "probe": "tsx scripts/probe-workarounds.ts",
    "dev:models": "tsx scripts/dev-models.ts",
    "code:fetch_poe_model": "tsx scripts/fetch-poe-model.ts",
    "prepare": "husky",
    "secrets": "trufflehog filesystem . --no-update --fail --exclude-paths=.trufflehogignore"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.42",
    "@ai-sdk/openai": "3.0.27",
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@ai-sdk/provider": "3.0.8",
    "@ai-sdk/provider-utils": "4.0.14"
  },
  "peerDependencies": {
    "ai": ">=6.0.0"
  },
  "devDependencies": {
    "@semantic-release/exec": "^7.1.0",
    "ai": "^6.0.68",
    "commander": "^12.0.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.2",
    "husky": "^9.1.7",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.0-beta.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poe-platform/ai-sdk-provider-poe.git"
  }
}
